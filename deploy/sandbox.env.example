# Copy to ~/.config/sandbox.env and edit. All values are optional; defaults shown.
# The systemd unit loads this via EnvironmentFile.

# --- concurrency / queue ---
# SANDBOX_WORKERS=4              # parallel sandboxes
# SANDBOX_QUEUE_DEPTH=32         # queued jobs before 429
# SANDBOX_JOB_TTL_S=300          # async job retention
# SANDBOX_SHUTDOWN_GRACE_S=35    # drain window on shutdown

# --- persistence / janitor ---
# SANDBOX_PERSIST=1              # 0 disables run history
# SANDBOX_JANITOR_INTERVAL_S=60
# SANDBOX_JANITOR_MAX_AGE_S=300

# --- auth (empty = disabled; create keys with scripts/make_key.py) ---
# SANDBOX_API_KEYS=sk_key1,sk_key2   # or manage a hashed key file

# --- rate limiting (0 = off) ---
# SANDBOX_RATE_PER_MIN=0         # requests/min per identity
# SANDBOX_MAX_INFLIGHT=0         # concurrent runs per identity

# --- abuse detection ---
# SANDBOX_ABUSE_THRESHOLD=0      # 0 = detect-only (never auto-block)
# SANDBOX_ABUSE_WINDOW_S=300

# --- multi-tenant hardening ---
# SANDBOX_CACHE_PER_IDENTITY=0   # 1 = isolate build caches per identity

# --- resilience ---
# SANDBOX_LAUNCH_RETRIES=2       # retries on transient sandbox-launch failures
